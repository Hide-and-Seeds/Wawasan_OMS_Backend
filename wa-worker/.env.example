# wa-worker/.env  — copy to .env and fill in.
WA_WORKER_SECRET=change-me-to-a-long-random-string   # MUST equal the backend's WHATSAPP_WORKER_SECRET
PORT=8787
# System Chromium path (puppeteer-core ships NO browser). On Debian/Ubuntu:
#   sudo apt-get install -y chromium  →  /usr/bin/chromium
CHROME_PATH=/usr/bin/chromium
# Canonical OMS backend URL — set this to TURN ON the drip sender.
APP_URL=https://wawasan-oms-backend.vercel.app

# sql-account-bridge/.env  — copy to .env and fill in.  Run: node --env-file=.env bridge.mjs

# Where to POST. Keep the /api/orders/webhook/sql-account path.
WEBHOOK_URL=https://wawasan-oms-backend.vercel.app/api/orders/webhook/sql-account
# MUST equal the backend's SQL_ACCOUNT_WEBHOOK_SECRET.
WEBHOOK_SECRET=change-me-to-match-the-backend

# Where invoices come from:  csv (works now) | firebird | sdk (stubs)
SOURCE=csv
# 0 = run once then exit (use Windows Task Scheduler / cron). >0 = loop every N seconds.
POLL_SECONDS=0
# Remembers which Doc Nos were already sent so re-runs never double-create.
STATE_FILE=./state.json

# ── SOURCE=csv ───────────────────────────────────────────────
# One exported invoice CSV, or a folder of them (CSV_DIR).
CSV_FILE=./invoices.csv
# CSV_DIR=./inbox
# Columns auto-detect by common names. If a column isn't found, run with
# --dry-run, read which header it wants, and map exact header text here:
# CSV_MAP={"docNo":"Doc No","customer":"Company Name","sku":"Item Code","name":"Description","qty":"Qty","uom":"UOM","date":"Doc Date","po":"Your Ref","terms":"Terms"}

# ── SOURCE=firebird  (live read of the SQL Account .FDB; run on the on-prem PC) ──
# Install once on that PC:  npm i node-firebird
# FB_HOST=127.0.0.1                 # the PC that hosts SQL Account / Firebird
# FB_PORT=3050
# FB_DATABASE=C:\\eStream\\SQLAccounting\\Share\\YOURCOMPANY.FDB
# FB_USER=SYSDBA
# FB_PASSWORD=masterkey
# FB_ENCODING=UTF8
#
# FB_SQL — the SELECT, ONE ROW PER INVOICE LINE. Alias columns to these names so
# the same auto-mapper as the CSV path picks them up (docno, customer, sku, name,
# qty, uom, docdate, po, terms, plus deliveryaddress1..4). SQL Account's real
# table names vary by version — open the .FDB (FlameRobin / isql) and confirm
# them; the names below are a STARTING TEMPLATE, not guaranteed.
# CONFIRMED 2026-06-13 against a real SQL Account DB (Education, ODS13/Firebird4):
# sales invoices live in SL_IV (header) + SL_IVDTL (lines), joined on DOCKEY.
# SL_IV already carries COMPANYNAME + delivery address (DADDRESS1-4/DPOSTCODE/DCITY/
# DSTATE), so no customer join is needed. CANCELLED is a BOOLEAN (filter = FALSE).
# Reading the DB returns a real DATE (no M/D-vs-D/M ambiguity, unlike CSV/PDF text).
# FB_SQL=SELECT h.DOCNO AS docno, h.COMPANYNAME AS customer, h.PHONE1 AS contact, h.DOCDATE AS docdate, h.DOCREF1 AS po, h.TERMS AS terms, h.DADDRESS1 AS deliveryaddress1, h.DADDRESS2 AS deliveryaddress2, h.DADDRESS3 AS deliveryaddress3, h.DADDRESS4 AS deliveryaddress4, h.DPOSTCODE AS deliveryaddress5, h.DCITY AS deliveryaddress6, h.DSTATE AS deliveryaddress7, d.ITEMCODE AS sku, d.DESCRIPTION AS name, d.QTY AS qty, d.UOM AS uom FROM SL_IV h JOIN SL_IVDTL d ON d.DOCKEY = h.DOCKEY WHERE h.CANCELLED = FALSE AND UPPER(h.DOCNO) NOT LIKE 'L%' AND h.DOCDATE >= ? ORDER BY h.DOCNO, d.SEQ
#
# Optional: bind one '?' in FB_SQL to "N days back from today" (incremental pull).
# FB_SINCE_DAYS=7

# ── SOURCE=sdk  (fill in once you have SDK access) ──
# SDK_LOGIN=admin
# SDK_PASSWORD=
# SDK_DCF=C:\\path\\to\\company.dcf

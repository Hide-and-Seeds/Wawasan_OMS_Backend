# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── Auth (JWT) ───
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ─── Supabase Postgres ───
# Use the CONNECTION POOLER string (Transaction mode, port 6543) for serverless/Vercel.
# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction pooler".
DATABASE_URL=postgres://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Set to "false" only for a local Postgres without TLS.
DATABASE_SSL=true
PG_POOL_MAX=5

# ─── Supabase Storage (file uploads) ───
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=oms-uploads

# ─── File uploads ───
MAX_FILE_SIZE=10485760

# ─── Email (SMTP for password resets) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@wawasancandle.com

# ─── CORS ───
# Comma-separated list of allowed frontend origins (your Vercel URL goes here in prod).
FRONTEND_URL=http://localhost:5173

# ─── SQL Account webhook ───
SQL_ACCOUNT_WEBHOOK_SECRET=some-shared-secret

# ─── Scheduled jobs (Vercel cron) ───
# Vercel auto-sends this as `Authorization: Bearer <CRON_SECRET>` to cron paths.
# REQUIRED for the daily enqueue + morning-brief crons to be authorized.
CRON_SECRET=change-me-to-a-long-random-string

# ─── WhatsApp auto-messages ───
# LEAVE WHATSAPP_WORKER_URL BLANK to use the safe 'log' provider (queues + "sends"
# to the server log — fully testable with no SIM). Set it to the always-on
# wa-worker's public URL to send for real. ⚠ Link a DEDICATED disposable SIM only.
WHATSAPP_WORKER_URL=
WHATSAPP_WORKER_SECRET=change-me-to-a-long-random-string
WHATSAPP_ADMIN_TO=                 # phone that receives the morning brief, e.g. 60123456789
WHATSAPP_DAILY_CAP=60              # max auto-sends per day
WHATSAPP_WINDOW_START=9            # daytime send window (local hour, inclusive)
WHATSAPP_WINDOW_END=21            # (local hour, exclusive)
WHATSAPP_TZ_OFFSET_MIN=480         # local tz offset in minutes (480 = UTC+8 Malaysia)
